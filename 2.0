<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Vibe 收藏馆 - 潮流艺术品级个人馆藏</title>
    <style>
        /* 极致现代黑金配色 & 全局复位 */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
        }
        :root {
            --bg-primary: #0a0a0c;
            --bg-secondary: #141418;
            --bg-tertiary: #1e1e24;
            --accent: #d4af37; /* 经典流沙金 */
            --accent-hover: #f3cf55;
            --text-primary: #ffffff;
            --text-secondary: #a0a0ab;
            --text-muted: #71717a;
            --border: #27272a;
            --success: #10b981;
            --danger: #ef4444;
            --shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            --font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }
        body {
            background-color: var(--bg-primary);
            color: var(--text-primary);
            font-family: var(--font);
            line-height: 1.5;
            padding-bottom: 80px;
            overflow-x: hidden;
        }

        /* 极简自救控制台 (防白屏底牌) */
        #error-boundary-handler {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #0f0f11;
            z-index: 99999;
            padding: 30px;
            text-align: center;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }
        #error-boundary-handler h2 {
            color: var(--danger);
            margin-bottom: 15px;
            font-size: 24px;
        }
        #error-boundary-handler p {
            color: var(--text-secondary);
            margin-bottom: 25px;
            max-width: 400px;
            font-size: 14px;
        }
        .rescue-btn {
            background: var(--accent);
            color: #000;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.2s;
        }
        .rescue-btn:hover {
            background: var(--accent-hover);
        }

        /* 顶部导航栏 */
        header {
            background: rgba(10, 10, 12, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 100;
            padding: 16px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo-area {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .logo-icon {
            color: var(--accent);
            width: 24px;
            height: 24px;
        }
        .logo-text {
            font-size: 18px;
            font-weight: 800;
            letter-spacing: 2px;
            background: linear-gradient(135deg, #fff 0%, var(--accent) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* 核心看板 - 潮流美学卡片 */
        .dashboard-container {
            max-width: 1200px;
            margin: 24px auto;
            padding: 0 20px;
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 16px;
            margin-bottom: 30px;
        }
        .stat-card {
            background: linear-gradient(145deg, var(--bg-secondary), var(--bg-primary));
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }
        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: var(--accent);
            opacity: 0.7;
        }
        .stat-label {
            font-size: 12px;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }
        .stat-value {
            font-size: 28px;
            font-weight: 800;
            letter-spacing: -0.5px;
        }
        .stat-change {
            font-size: 12px;
            margin-top: 6px;
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .trend-up { color: var(--success); }
        .trend-down { color: var(--danger); }

        /* 操作栏 */
        .action-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            gap: 16px;
            flex-wrap: wrap;
        }
        .search-wrapper {
            position: relative;
            flex: 1;
            min-width: 260px;
        }
        .search-input {
            width: 100%;
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            color: var(--text-primary);
            padding: 12px 16px 12px 42px;
            border-radius: 12px;
            font-size: 14px;
            transition: all 0.2s;
        }
        .search-input:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 2px rgba(212, 175, 55, 0.2);
        }
        .search-icon-svg {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            width: 18px;
            height: 18px;
        }
        .add-btn {
            background: var(--accent);
            color: #000;
            font-weight: 700;
            border: none;
            padding: 12px 24px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 4px 12px rgba(212, 175, 55, 0.3);
        }
        .add-btn:hover {
            background: var(--accent-hover);
            transform: translateY(-1px);
        }

        /* 潮流卡片列表 */
        .items-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px;
        }
        .item-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            display: flex;
            flex-direction: column;
            position: relative;
        }
        .item-card:hover {
            transform: translateY(-6px);
            border-color: rgba(212, 175, 55, 0.4);
        }
        .image-container {
            width: 100%;
            aspect-ratio: 1;
            background: #18181c;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .item-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s;
        }
        .item-card:hover .item-img {
            transform: scale(1.05);
        }
        .no-img-placeholder {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            color: var(--text-muted);
        }
        .no-img-placeholder svg {
            width: 48px;
            height: 48px;
            opacity: 0.5;
        }
        .category-tag {
            position: absolute;
            top: 12px;
            left: 12px;
            background: rgba(10, 10, 12, 0.75);
            border: 1px solid rgba(255,255,255,0.1);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.5px;
        }
        .rating-tag {
            position: absolute;
            top: 12px;
            right: 12px;
            background: rgba(212, 175, 55, 0.9);
            color: #000;
            padding: 4px 8px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 2px;
        }

        /* 卡片内容区 */
        .card-body {
            padding: 18px;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        .item-title {
            font-size: 17px;
            font-weight: 700;
            line-height: 1.3;
            margin-bottom: 6px;
            color: var(--text-primary);
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .brand-text {
            font-size: 12px;
            color: var(--text-secondary);
            margin-bottom: 14px;
        }
        .price-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            border-top: 1px solid rgba(255,255,255,0.05);
            padding-top: 12px;
        }
        .price-block {
            display: flex;
            flex-direction: column;
        }
        .price-label {
            font-size: 10px;
            color: var(--text-muted);
            margin-bottom: 2px;
            text-transform: uppercase;
        }
        .cost-val {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-secondary);
        }
        .value-val {
            font-size: 18px;
            font-weight: 800;
            color: var(--accent);
        }

        /* 详情/新增 弹窗 (Modal) */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(5, 5, 6, 0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            z-index: 1000;
            justify-content: center;
            align-items: center;
            padding: 20px;
            overflow-y: auto;
        }
        .modal-content {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            width: 100%;
            max-width: 550px;
            border-radius: 24px;
            position: relative;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.8);
            animation: modalEnter 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            max-height: 90vh;
            display: flex;
            flex-direction: column;
        }
        @keyframes modalEnter {
            from { transform: scale(0.95); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }
        .modal-header {
            padding: 20px 24px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .modal-title {
            font-size: 18px;
            font-weight: 800;
            letter-spacing: 0.5px;
        }
        .close-btn {
            background: none;
            border: none;
            color: var(--text-secondary);
            cursor: pointer;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
            transition: 0.2s;
        }
        .close-btn:hover {
            color: #fff;
            background: rgba(255,255,255,0.1);
        }
        .modal-body {
            padding: 24px;
            overflow-y: auto;
            flex: 1;
        }

        /* 炫酷高保真表单 */
        .form-group {
            margin-bottom: 18px;
        }
        .form-label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-secondary);
            margin-bottom: 8px;
        }
        .form-control {
            width: 100%;
            background: var(--bg-primary);
            border: 1px solid var(--border);
            color: var(--text-primary);
            padding: 12px 16px;
            border-radius: 12px;
            font-size: 14px;
            transition: all 0.2s;
        }
        .form-control:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 2px rgba(212, 175, 55, 0.15);
        }
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        /* 潮流图片上传池 */
        .uploader-zone {
            border: 2px dashed var(--border);
            background: var(--bg-primary);
            border-radius: 16px;
            padding: 30px 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }
        .uploader-zone:hover {
            border-color: var(--accent);
            background: rgba(212,175,55,0.02);
        }
        .uploader-preview {
            width: 100%;
            height: 180px;
            object-fit: cover;
            border-radius: 10px;
            display: none;
        }
        .uploader-icon {
            color: var(--text-muted);
            width: 36px;
            height: 36px;
        }

        /* 模态框底部 */
        .modal-footer {
            padding: 18px 24px;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: flex-end;
            gap: 12px;
        }
        .btn-secondary {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text-secondary);
            padding: 10px 20px;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
        }
        .btn-secondary:hover {
            background: rgba(255,255,255,0.05);
            color: #fff;
        }
        .btn-danger {
            background: var(--danger);
            border: none;
            color: #fff;
            padding: 10px 20px;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
        }
        .btn-danger:hover {
            opacity: 0.9;
        }

        /* 加载中状态骨架 */
        #loading-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--bg-primary);
            z-index: 10000;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 16px;
        }
        .spinner {
            width: 40px;
            height: 40px;
            border: 3px solid rgba(212,175,55,0.1);
            border-radius: 50%;
            border-top-color: var(--accent);
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* 移动端优化 */
        @media (max-width: 600px) {
            .stats-grid {
                grid-template-columns: 1fr 1fr;
            }
            .modal-content {
                max-height: 95vh;
            }
            header {
                padding: 14px 16px;
            }
            .logo-text {
                font-size: 16px;
            }
            .action-bar {
                flex-direction: column;
                align-items: stretch;
            }
            .add-btn {
                justify-content: center;
            }
        }
    </style>
</head>
<body>

    <!-- 容错沙箱，防止未知报错导致的白屏 -->
    <div id="error-boundary-handler">
        <h2>⚠️ 遇到未知的数据处理错误</h2>
        <p>系统已安全隔离本次异常。如果您刚才导入了损坏的图片或存在坏缓存，请点击下方按钮一键重置系统环境。</p>
        <button class="rescue-btn" onclick="hardResetSystem()">一键强力清除缓存并重塑</button>
    </div>

    <!-- 极速启动加载屏幕 -->
    <div id="loading-screen">
        <div class="spinner"></div>
        <div style="font-size: 14px; color: var(--text-secondary); letter-spacing: 2px;">VIBE 馆藏载入中...</div>
    </div>

    <!-- 主体头部 -->
    <header>
        <div class="logo-area">
            <svg class="logo-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
            <span class="logo-text">VIBE COLLECTION</span>
        </div>
        <div style="font-size: 12px; color: var(--text-secondary); border: 1px solid var(--border); padding: 4px 10px; border-radius: 20px; background: var(--bg-secondary);">
            H5 极速高稳版
        </div>
    </header>

    <!-- 看板主区 -->
    <main class="dashboard-container">
        
        <!-- 统计看板 -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-label">馆藏总市值</div>
                <div class="stat-value" id="stat-total-value">¥0.00</div>
                <div class="stat-change" id="stat-profit-percent">--</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">总购入成本</div>
                <div class="stat-value" id="stat-total-cost">¥0.00</div>
                <div class="stat-change" style="color: var(--text-muted);">
                    初始建仓成本
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-label">已录入馆藏</div>
                <div class="stat-value" id="stat-total-count">0 件</div>
                <div class="stat-change" style="color: var(--text-muted);" id="stat-last-update">
                    实时本地存贮
                </div>
            </div>
        </div>

        <!-- 搜索与添加操作栏 -->
        <div class="action-bar">
            <div class="search-wrapper">
                <svg class="search-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" class="search-input" id="search-input" placeholder="输入名称、品牌、序列号或分类搜索..." oninput="renderItems()">
            </div>
            <button class="add-btn" onclick="openAddModal()">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                登记全新珍藏
            </button>
        </div>

        <!-- 潮流商品列表 -->
        <div class="items-grid" id="items-grid">
            <!-- 动态生成卡片 -->
        </div>

    </main>

    <!-- “登记/编辑馆藏”通用模态框 -->
    <div class="modal-overlay" id="item-modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title" id="modal-title">登记全新珍藏</h3>
                <button class="close-btn" onclick="closeModal()">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
            <div class="modal-body">
                <form id="item-form" onsubmit="saveItem(event)">
                    <input type="hidden" id="form-item-id">
                    
                    <!-- 极速高保真图片上传区 -->
                    <div class="form-group">
                        <label class="form-label">馆藏实物摄影</label>
                        <div class="uploader-zone" onclick="triggerFileInput()">
                            <svg class="uploader-icon" id="uploader-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                                <polyline points="21 15 16 10 5 21"></polyline>
                            </svg>
                            <span id="uploader-text" style="font-size: 13px; color: var(--text-secondary);">点击此处上传高精大图 (支持拍照/相册)</span>
                            <img class="uploader-preview" id="uploader-preview-img" alt="Preview">
                        </div>
                        <input type="file" id="form-file-input" accept="image/*" style="display: none;" onchange="handleFileSelect(event)">
                    </div>

                    <div class="form-group">
                        <label class="form-label">收藏名</label>
                        <input type="text" class="form-control" id="form-title" placeholder="如：Bearbrick 梵高自画像 1000%" required>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">品牌/厂商</label>
                            <input type="text" class="form-control" id="form-brand" placeholder="如：MEDICOM TOY" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">分类</label>
                            <select class="form-control" id="form-category" style="background-color: var(--bg-primary);">
                                <option value="潮流玩具">潮流玩具</option>
                                <option value="限量潮鞋">限量潮鞋</option>
                                <option value="潮牌服饰">潮牌服饰</option>
                                <option value="艺术版画">艺术版画</option>
                                <option value="数码极客">数码极客</option>
                                <option value="其它馆藏">其它馆藏</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">入手原价 (¥)</label>
                            <input type="number" class="form-control" id="form-cost" placeholder="0.00" step="0.01" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">当前估值 (¥)</label>
                            <input type="number" class="form-control" id="form-value" placeholder="0.00" step="0.01" required>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">评级分 (1-10)</label>
                            <input type="number" class="form-control" id="form-rating" placeholder="10.0" min="1" max="10" step="0.1">
                        </div>
                        <div class="form-group">
                            <label class="form-label">序列号/版本</label>
                            <input type="text" class="form-control" id="form-serial" placeholder="如：No. 128 / 500">
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-secondary" onclick="closeModal()">取消</button>
                <button type="button" class="btn-danger" id="delete-btn" style="display: none;" onclick="deleteCurrentItem()">删除馆藏</button>
                <button type="submit" form="item-form" class="add-btn" style="box-shadow: none;">保留馆藏</button>
            </div>
        </div>
    </div>

    <script>
        // 初始化默认高美感馆藏数据 (以防本地为空或报错)
        const DEFAULT_ITEMS = [
            {
                id: "item-default-1",
                title: "Bearbrick 梵高自画像 1000%",
                brand: "MEDICOM TOY",
                category: "潮流玩具",
                cost: 4500,
                value: 6200,
                rating: 9.8,
                serial: "Limited 500 Pcs",
                image: ""
            },
            {
                id: "item-default-2",
                title: "Air Jordan 1 Retro High 'Chicago'",
                brand: "Nike / Off-White",
                category: "限量潮鞋",
                cost: 1299,
                value: 11500,
                rating: 9.5,
                serial: "AA3834-101",
                image: ""
            }
        ];

        let collectionItems = [];
        let uploadedImageBase64 = "";

        // 万无一失的初始化流程
        window.addEventListener('DOMContentLoaded', () => {
            try {
                // 1. 加载本地数据并极力防错
                const rawData = localStorage.getItem('vibe_collection_items');
                if (rawData) {
                    const parsed = JSON.parse(rawData);
                    if (Array.isArray(parsed)) {
                        collectionItems = parsed;
                    } else {
                        collectionItems = DEFAULT_ITEMS;
                    }
                } else {
                    collectionItems = DEFAULT_ITEMS;
                    localStorage.setItem('vibe_collection_items', JSON.stringify(DEFAULT_ITEMS));
                }
            } catch (err) {
                console.error("Local data corrupted, fallback to defaults.", err);
                collectionItems = DEFAULT_ITEMS;
            }

            // 2. 渲染主画布
            renderDashboard();
            renderItems();

            // 3. 渐隐载入屏幕，露出高保真界面
            setTimeout(() => {
                const loader = document.getElementById('loading-screen');
                if (loader) loader.style.display = 'none';
            }, 300);
        });

        // 统一错误防护机制 (防御性高招)
        window.onerror = function(message, source, lineno, colno, error) {
            document.getElementById('error-boundary-handler').style.display = 'flex';
            if (document.getElementById('loading-screen')) {
                document.getElementById('loading-screen').style.display = 'none';
            }
            return false;
        };

        // 一键清空缓存，挽救白屏自救方案
        function hardResetSystem() {
            localStorage.clear();
            location.reload();
        }

        // 看板总数据计算 (带防 NaN 重构)
        function renderDashboard() {
            let totalCost = 0;
            let totalValue = 0;

            collectionItems.forEach(item => {
                totalCost += Number(item.cost) || 0;
                totalValue += Number(item.value) || 0;
            });

            // 盈亏幅度计算
            let profitPercentText = "--";
            let trendClass = "";

            if (totalCost > 0) {
                const diff = totalValue - totalCost;
                const percent = (diff / totalCost) * 100;
                const sign = percent >= 0 ? "+" : "";
                profitPercentText = `${sign}${percent.toFixed(1)}% 溢价幅度`;
                trendClass = percent >= 0 ? "trend-up" : "trend-down";
            }

            // 更新 DOM
            document.getElementById('stat-total-value').innerText = `¥${totalValue.toLocaleString('zh-CN', {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
            document.getElementById('stat-total-cost').innerText = `¥${totalCost.toLocaleString('zh-CN', {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
            document.getElementById('stat-total-count').innerText = `${collectionItems.length} 件`;

            const profitEl = document.getElementById('stat-profit-percent');
            profitEl.className = `stat-change ${trendClass}`;
            profitEl.innerText = profitPercentText;
        }

        // 渲染馆藏主列表
        function renderItems() {
            const grid = document.getElementById('items-grid');
            const searchQuery = document.getElementById('search-input').value.toLowerCase().trim();
            grid.innerHTML = "";

            const filtered = collectionItems.filter(item => {
                const titleMatch = (item.title || "").toLowerCase().includes(searchQuery);
                const brandMatch = (item.brand || "").toLowerCase().includes(searchQuery);
                const categoryMatch = (item.category || "").toLowerCase().includes(searchQuery);
                const serialMatch = (item.serial || "").toLowerCase().includes(searchQuery);
                return titleMatch || brandMatch || categoryMatch || serialMatch;
            });

            if (filtered.length === 0) {
                grid.innerHTML = `
                    <div style="grid-column: 1/-1; text-align: center; padding: 60px 20px; color: var(--text-muted);">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom: 12px; opacity: 0.5;">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        <p style="font-size: 14px;">没有搜寻到相关潮流馆藏</p>
                    </div>
                `;
                return;
            }

            filtered.forEach(item => {
                const card = document.createElement('div');
                card.className = "item-card";
                card.onclick = () => openEditModal(item.id);

                // 判断图像渲染
                let imgHTML = "";
                if (item.image) {
                    imgHTML = `<img src="${item.image}" class="item-img" alt="${item.title}" loading="lazy">`;
                } else {
                    imgHTML = `
                        <div class="no-img-placeholder">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                                <polyline points="21 15 16 10 5 21"></polyline>
                            </svg>
                            <span style="font-size: 11px;">高拟真图像待摄影</span>
                        </div>
                    `;
                }

                // 评分标签
                const ratingHTML = item.rating ? `
                    <div class="rating-tag">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                        </svg>
                        ${Number(item.rating).toFixed(1)}
                    </div>
                ` : "";

                card.innerHTML = `
                    <div class="image-container">
                        <span class="category-tag">${item.category || "其它"}</span>
                        ${ratingHTML}
                        ${imgHTML}
                    </div>
                    <div class="card-body">
                        <div>
                            <h4 class="item-title" title="${item.title}">${item.title}</h4>
                            <div class="brand-text">${item.brand} ${item.serial ? `• ${item.serial}` : ''}</div>
                        </div>
                        <div class="price-row">
                            <div class="price-block">
                                <span class="price-label">入手原价</span>
                                <span class="cost-val">¥${(Number(item.cost) || 0).toLocaleString()}</span>
                            </div>
                            <div class="price-block" style="text-align: right;">
                                <span class="price-label" style="color: var(--accent);">当前估值</span>
                                <span class="value-val">¥${(Number(item.value) || 0).toLocaleString()}</span>
                            </div>
                        </div>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        // 打开“登记全新珍藏”模态框
        function openAddModal() {
            document.getElementById('modal-title').innerText = "登记全新珍藏";
            document.getElementById('item-form').reset();
            document.getElementById('form-item-id').value = "";
            document.getElementById('delete-btn').style.display = "none";
            
            // 重置图像预览池
            uploadedImageBase64 = "";
            document.getElementById('uploader-icon-svg').style.display = "block";
            document.getElementById('uploader-text').style.display = "block";
            document.getElementById('uploader-preview-img').style.display = "none";
            document.getElementById('uploader-preview-img').src = "";

            document.getElementById('item-modal').style.display = "flex";
        }

        // 打开“编辑/删除珍藏”模态框
        function openEditModal(id) {
            const item = collectionItems.find(x => x.id === id);
            if (!item) return;

            document.getElementById('modal-title').innerText = "馆藏高精解析";
            document.getElementById('form-item-id').value = item.id;
            document.getElementById('form-title').value = item.title || "";
            document.getElementById('form-brand').value = item.brand || "";
            document.getElementById('form-category').value = item.category || "潮流玩具";
            document.getElementById('form-cost').value = item.cost || "";
            document.getElementById('form-value').value = item.value || "";
            document.getElementById('form-rating').value = item.rating || "";
            document.getElementById('form-serial').value = item.serial || "";

            // 加载已有图片
            if (item.image) {
                uploadedImageBase64 = item.image;
                document.getElementById('uploader-icon-svg').style.display = "none";
                document.getElementById('uploader-text').style.display = "none";
                document.getElementById('uploader-preview-img').style.display = "block";
                document.getElementById('uploader-preview-img').src = item.image;
            } else {
                uploadedImageBase64 = "";
                document.getElementById('uploader-icon-svg').style.display = "block";
                document.getElementById('uploader-text').style.display = "block";
                document.getElementById('uploader-preview-img').style.display = "none";
                document.getElementById('uploader-preview-img').src = "";
            }

            document.getElementById('delete-btn').style.display = "block";
            document.getElementById('item-modal').style.display = "flex";
        }

        function closeModal() {
            document.getElementById('item-modal').style.display = "none";
        }

        // 触发本地或拍照相册上传
        function triggerFileInput() {
            document.getElementById('form-file-input').click();
        }

        // 高画质压缩及防爆显卡 Blob 处理
        function handleFileSelect(e) {
            const file = e.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(evt) {
                // 压缩图片流程，防止大图高画质导致存储爆棚
                const img = new Image();
                img.onload = function() {
                    const canvas = document.createElement('canvas');
                    let width = img.width;
                    let height = img.height;

                    // 维持 1000px 以内的高清晰度
                    const max_size = 1000;
                    if (width > height) {
                        if (width > max_size) {
                            height *= max_size / width;
                            width = max_size;
                        }
                    } else {
                        if (height > max_size) {
                            width *= max_size / height;
                            height = max_size;
                        }
                    }

                    canvas.width = width;
                    canvas.height = height;

                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, width, height);

                    // 转换为中高保真度的 jpeg base64
                    const dataUrl = canvas.toDataURL('image/jpeg', 0.8);
                    uploadedImageBase64 = dataUrl;

                    // 更替上传框预览
                    document.getElementById('uploader-icon-svg').style.display = "none";
                    document.getElementById('uploader-text').style.display = "none";
                    document.getElementById('uploader-preview-img').style.display = "block";
                    document.getElementById('uploader-preview-img').src = dataUrl;
                };
                img.src = evt.target.result;
            };
            reader.readAsDataURL(file);
        }

        // 保存/新增收藏数据
        function saveItem(e) {
            e.preventDefault();

            const id = document.getElementById('form-item-id').value;
            const title = document.getElementById('form-title').value.trim();
            const brand = document.getElementById('form-brand').value.trim();
            const category = document.getElementById('form-category').value;
            const cost = parseFloat(document.getElementById('form-cost').value) || 0;
            const value = parseFloat(document.getElementById('form-value').value) || 0;
            const rating = parseFloat(document.getElementById('form-rating').value) || null;
            const serial = document.getElementById('form-serial').value.trim();

            const newItem = {
                id: id ? id : 'item-' + Date.now(),
                title: title,
                brand: brand,
                category: category,
                cost: cost,
                value: value,
                rating: rating,
                serial: serial,
                image: uploadedImageBase64
            };

            if (id) {
                // 编辑现有项
                const idx = collectionItems.findIndex(x => x.id === id);
                if (idx !== -1) {
                    collectionItems[idx] = newItem;
                }
            } else {
                // 新增
                collectionItems.unshift(newItem);
            }

            // 同步本地
            localStorage.setItem('vibe_collection_items', JSON.stringify(collectionItems));

            // 全局重绘
            renderDashboard();
            renderItems();
            closeModal();
        }

        // 删除馆藏项
        function deleteCurrentItem() {
            const id = document.getElementById('form-item-id').value;
            if (!id) return;

            collectionItems = collectionItems.filter(x => x.id !== id);
            localStorage.setItem('vibe_collection_items', JSON.stringify(collectionItems));

            renderDashboard();
            renderItems();
            closeModal();
        }
    </script>
</body>
</html>
