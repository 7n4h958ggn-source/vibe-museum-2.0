<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Vibe Museum - 个人电子收藏馆</title>
    
    <!-- iOS Web App Meta Tags -->
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Vibe馆">
    
    <!-- Tailwind CSS for modern rapid styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Fonts: Inter and Playfair Display for premium museum look matching image_f066e0.jpg -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,700;1,400&display=swap" rel="stylesheet">
    
    <!-- React and Babel CDNs for robust component structure in single file -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

    <style>
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            -webkit-tap-highlight-color: transparent;
            background-color: #f6f6f3;
        }
        .serif-font {
            font-family: 'Playfair Display', Georgia, serif;
        }
        /* Custom scrollbars for beautiful aesthetic list navigation */
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        /* Dynamic iOS PWA Home Indicator padding adjustment */
        .pb-safe {
            padding-bottom: calc(env(safe-area-inset-bottom) + 1rem);
        }
        .pt-safe {
            padding-top: calc(env(safe-area-inset-top) + 1rem);
        }
        /* Custom grayscaling for SOLD OUT items to match high-end photo treatments in image_f066e0.jpg */
        .sold-out-grayscale {
            filter: grayscale(90%) contrast(95%);
            opacity: 0.65;
        }
        /* Shimmer effect for DeepSeek AI analysis loading states */
        @keyframes shimmer {
            100% { transform: translateX(100%); }
        }
        .shimmer {
            position: relative;
            overflow: hidden;
        }
        .shimmer::after {
            position: absolute;
            top: 0; right: 0; bottom: 0; left: 0;
            transform: translateX(-100%);
            background-image: linear-gradient(
                90deg,
                rgba(255, 255, 255, 0) 0%,
                rgba(255, 255, 255, 0.4) 20%,
                rgba(255, 255, 255, 0.6) 60%,
                rgba(255, 255, 255, 0) 100%
            );
            animation: shimmer 1.5s infinite;
            content: '';
        }
    </style>
</head>
<body class="text-[#20252c] overflow-x-hidden">

    <div id="app"></div>

    <script type="text/babel">
        const { useState, useEffect, useMemo, useRef } = React;

        // Custom High-Quality SVG Icons Component to reduce layout thrashing
        function Icon({ name, className = "w-5 h-5", strokeWidth = 2 }) {
            const icons = {
                search: (
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" className={className} strokeWidth={strokeWidth}>
                        <path strokeLinecap="round" strokeLinejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                ),
                plus: (
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" className={className} strokeWidth={strokeWidth}>
                        <path strokeLinecap="round" strokeLinejoin="round" d="M12 4v16m8-8H4" />
                    </svg>
                ),
                settings: (
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" className={className} strokeWidth={strokeWidth}>
                        <path strokeLinecap="round" strokeLinejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                        <path strokeLinecap="round" strokeLinejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                ),
                back: (
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" className={className} strokeWidth={strokeWidth}>
                        <path strokeLinecap="round" strokeLinejoin="round" d="M15 19l-7-7 7-7" />
                    </svg>
                ),
                sparkles: (
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" className={className} strokeWidth={strokeWidth}>
                        <path strokeLinecap="round" strokeLinejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                    </svg>
                ),
                location: (
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" className={className} strokeWidth={strokeWidth}>
                        <path strokeLinecap="round" strokeLinejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path strokeLinecap="round" strokeLinejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                ),
                trash: (
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" className={className} strokeWidth={strokeWidth}>
                        <path strokeLinecap="round" strokeLinejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                ),
                edit: (
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" className={className} strokeWidth={strokeWidth}>
                        <path strokeLinecap="round" strokeLinejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                    </svg>
                ),
                share: (
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" className={className} strokeWidth={strokeWidth}>
                        <path strokeLinecap="round" strokeLinejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                    </svg>
                ),
                imagePlaceholder: (
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" className={className} strokeWidth={1.5}>
                        <path strokeLinecap="round" strokeLinejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                    </svg>
                ),
                trendUp: (
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" className={className} strokeWidth={2}>
                        <path strokeLinecap="round" strokeLinejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                    </svg>
                )
            };
            return icons[name] || null;
        }

        const safeGetLocalStorage = (key, defaultValue) => {
            try {
                const stored = localStorage.getItem(key);
                return stored ? JSON.parse(stored) : defaultValue;
            } catch (e) {
                console.error("LocalStorage read blocked:", e);
                return defaultValue;
            }
        };

        const safeSetLocalStorage = (key, value) => {
            try {
                localStorage.setItem(key, JSON.stringify(value));
            } catch (e) {
                console.error("LocalStorage write blocked:", e);
            }
        };

        const INITIAL_MOCK_ITEMS = [
            {
                id: "mock-item-1",
                name: "Molly 蒸汽朋克隐藏款",
                ip: "泡泡玛特",
                character: "Molly",
                tags: ["隐藏款", "盲盒", "蒸汽朋克"],
                status: "in_stock", 
                image_url: "https://images.unsplash.com/photo-1608889175123-8ec330b86f84?auto=format&fit=crop&q=80&w=600",
                purchase_price: 59,
                current_market_price: 380,
                price_history: [
                    { date: "2026-01-01", price: 59, source: "入手价" },
                    { date: "2026-03-15", price: 210, source: "DeepSeek估价" },
                    { date: "2026-06-10", price: 380, source: "估价" }
                ],
                location: {
                    name: "客厅A柜第三层",
                    description: "展架最深处，放在灯泡玩偶后面",
                    image_url: ""
                },
                created_at: "2026-01-01",
                notes: "蒸汽朋克风格非常惊艳，材质带有特殊的金属光泽漆面。"
            },
            {
                id: "mock-item-2",
                name: "星空马里奥 手办",
                ip: "任天堂",
                character: "马里奥",
                tags: ["限定", "摆件"],
                status: "in_stock", 
                image_url: "", 
                purchase_price: 150,
                current_market_price: 150,
                price_history: [
                    { date: "2026-05-12", price: 150, source: "入手价" }
                ],
                location: {
                    name: "电脑桌搁架",
                    description: "显示器右侧",
                    image_url: ""
                },
                created_at: "2026-05-12",
                notes: "经典无实物照片精品卡片展示，使用典雅灰白渐变背板兜底。"
            }
        ];

        function PriceTrendChart({ history, purchasePrice, currentPrice }) {
            const parsedHistory = Array.isArray(history) ? history : [];
            if (parsedHistory.length < 2) {
                return (
                    <div className="bg-[#fcfcf9] text-xs text-neutral-400 p-4 rounded-2xl border border-[#e5e5e0] text-center">
                        需要至少录入两组价格数据点来自动绘制波动曲线。
                    </div>
                );
            }

            const parsedData = parsedHistory.map(h => ({
                date: h?.date || "",
                price: parseFloat(h?.price) || 0,
                source: h?.source || ""
            })).sort((a, b) => new Date(a.date) - new Date(b.date));

            const minPrice = Math.min(...parsedData.map(d => d.price), purchasePrice) * 0.9;
            const maxPrice = Math.max(...parsedData.map(d => d.price), purchasePrice) * 1.1;
            const priceRange = maxPrice - minPrice || 1;

            const width = 500;
            const height = 180;
            const paddingLeft = 45;
            const paddingRight = 15;
            const paddingTop = 20;
            const paddingBottom = 30;

            const plotWidth = width - paddingLeft - paddingRight;
            const plotHeight = height - paddingTop - paddingBottom;

            const points = parsedData.map((d, index) => {
                const x = paddingLeft + (index / (parsedData.length - 1)) * plotWidth;
                const y = paddingTop + plotHeight - ((d.price - minPrice) / priceRange) * plotHeight;
                return { x, y, price: d.price, date: d.date, source: d.source };
            });

            const linePath = points.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x} ${p.y}`).join(' ');
            const areaPath = points.length > 0 
                ? `${linePath} L ${points[points.length - 1].x} ${height - paddingBottom} L ${points[0].x} ${height - paddingBottom} Z` 
                : '';

            return (
                <div className="bg-white border border-[#e5e5e0] rounded-2xl p-4 mt-2">
                    <div className="flex justify-between items-center mb-3">
                        <span className="text-xs font-semibold uppercase tracking-wider text-[#7c7c72]">市场历史追踪线</span>
                        <span className="text-xs text-[#20252c] font-medium">波动区间: ¥{minPrice.toFixed(0)} - ¥{maxPrice.toFixed(0)}</span>
                    </div>
                    <div className="relative">
                        <svg viewBox={`0 0 ${width} ${height}`} className="w-full h-auto">
                            <defs>
                                <linearGradient id="chartGradient" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%" stopColor="#20252c" stopOpacity="0.10" />
                                    <stop offset="100%" stopColor="#20252c" stopOpacity="0.00" />
                                </linearGradient>
                            </defs>
                            
                            {[0, 0.5, 1].map((ratio, idx) => {
                                const y = paddingTop + plotHeight * ratio;
                                const val = maxPrice - ratio * priceRange;
                                return (
                                    <g key={idx}>
                                        <line x1={paddingLeft} y1={y} x2={width - paddingRight} y2={y} stroke="#f0f0e8" strokeWidth="1" strokeDasharray="3 3" />
                                        <text x={paddingLeft - 8} y={y + 4} textAnchor="end" fill="#9c9c92" fontSize="9" className="font-mono">
                                            ¥{val.toFixed(0)}
                                        </text>
                                    </g>
                                );
                            })}

                            {areaPath && <path d={areaPath} fill="url(#chartGradient)" />}
                            <path d={linePath} fill="none" stroke="#20252c" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" />

                            {points.map((p, idx) => (
                                <g key={idx} className="group cursor-pointer">
                                    <circle cx={p.x} cy={p.y} r="4" fill="#20252c" stroke="#fff" strokeWidth="2" />
                                    <title>{`${p.date}\n¥${p.price} (${p.source})`}</title>
                                </g>
                            ))}
                        </svg>
                    </div>
                </div>
            );
        }

        function ImageFallback({ title, className = "w-full h-full" }) {
            return (
                <div className={`${className} bg-gradient-to-br from-[#f2f1ec] to-[#e7e5de] flex flex-col items-center justify-center p-6 text-center border border-[#e5e5e0] relative overflow-hidden`}>
                    <div className="absolute inset-4 border border-dashed border-[#d5d4cd] rounded-2xl opacity-60"></div>
                    <div className="p-4 bg-white/50 backdrop-blur-sm rounded-full border border-white/60 mb-3 relative z-10 text-[#7c7c72]">
                        <Icon name="imagePlaceholder" className="w-8 h-8 opacity-70" />
                    </div>
                    <span className="text-xs font-semibold tracking-wider text-[#7c7c72] uppercase relative z-10 serif-font">Vibe Museum</span>
                    <span className="text-[10px] text-[#9c9c92] tracking-widest uppercase mt-1 block relative z-10 font-mono">Archival Record / 尚无实拍影像</span>
                </div>
            );
        }

        function App() {
            const [items, setItems] = useState(() => {
                return safeGetLocalStorage("vibe_museum_items", INITIAL_MOCK_ITEMS);
            });
            const [selectedIP, setSelectedIP] = useState("全部");
            const [selectedCharacter, setSelectedCharacter] = useState("全部");
            const [searchQuery, setSearchQuery] = useState("");
            const [activeTab, setActiveTab] = useState("gallery"); 
            const [selectedItemId, setSelectedItemId] = useState(null);
            const [deepSeekKey, setDeepSeekKey] = useState(() => safeGetLocalStorage("vibe_deepseek_key", ""));
            const [showLocationPopover, setShowLocationPopover] = useState(false);
            const [toast, setToast] = useState(null);
            const [deleteConfirmId, setDeleteConfirmId] = useState(null);
            const [editingItem, setEditingItem] = useState(null);

            // Desktop slide/drag helpers
            const scrollContainerRef = useRef(null);
            const isDragging = useRef(false);
            const startX = useRef(0);
            const scrollLeft = useRef(0);

            // Custom Brand IPs
            const [customIPs, setCustomIPs] = useState(() => {
                return safeGetLocalStorage("vibe_custom_ips", ["全部", "泡泡玛特", "宝可梦", "积木熊", "任天堂", "高达", "其他"]);
            });

            // Form states
            const [formName, setFormName] = useState("");
            const [formIp, setFormIp] = useState("");
            const [formCharacter, setFormCharacter] = useState("");
            const [formTags, setFormTags] = useState("");
            const [formStatus, setFormStatus] = useState("in_stock");
            const [formImageUrl, setFormImageUrl] = useState("");
            const [formPurchasePrice, setFormPurchasePrice] = useState("");
            const [formCurrentMarketPrice, setFormCurrentMarketPrice] = useState("");
            const [formLocationName, setFormLocationName] = useState("");
            const [formLocationDescription, setFormLocationDescription] = useState("");
            const [formLocationImageUrl, setFormLocationImageUrl] = useState("");
            const [formNotes, setFormNotes] = useState("");

            const [linkToImport, setLinkToImport] = useState("");
            const [isParsingLink, setIsParsingLink] = useState(false);
            const [isEvaluating, setIsEvaluating] = useState(false);
            const [valuationMessage, setValuationMessage] = useState("");

            const triggerToast = (msg, type = "success") => {
                setToast({ msg, type });
                setTimeout(() => setToast(null), 3000);
            };

            const handleMouseDown = (e) => {
                if (!scrollContainerRef.current) return;
                isDragging.current = true;
                startX.current = e.pageX - scrollContainerRef.current.offsetLeft;
                scrollLeft.current = scrollContainerRef.current.scrollLeft;
            };

            const handleMouseLeave = () => {
                isDragging.current = false;
            };

            const handleMouseUp = () => {
                isDragging.current = false;
            };

            const handleMouseMove = (e) => {
                if (!isDragging.current || !scrollContainerRef.current) return;
                e.preventDefault();
                const x = e.pageX - scrollContainerRef.current.offsetLeft;
                const walk = (x - startX.current) * 1.5; // Scroll speed multiplier
                scrollContainerRef.current.scrollLeft = scrollLeft.current - walk;
            };

            // Comprehensive base64 image compression with auto-fallback to guarantee images load
            const compressPhoto = (file) => {
                return new Promise((resolve, reject) => {
                    const reader = new FileReader();
                    reader.onload = (event) => {
                        const img = new Image();
                        img.onload = () => {
                            try {
                                const canvas = document.createElement("canvas");
                                const MAX_WIDTH = 800;
                                const MAX_HEIGHT = 800;
                                let width = img.width;
                                let height = img.height;

                                if (width > height) {
                                    if (width > MAX_WIDTH) {
                                        height *= MAX_WIDTH / width;
                                        width = MAX_WIDTH;
                                    }
                                } else {
                                    if (height > MAX_HEIGHT) {
                                        width *= MAX_HEIGHT / height;
                                        height = MAX_HEIGHT;
                                    }
                                }

                                canvas.width = width;
                                canvas.height = height;
                                const ctx = canvas.getContext("2d");
                                ctx.drawImage(img, 0, 0, width, height);
                                
                                const compressedBase64 = canvas.toDataURL("image/jpeg", 0.8);
                                resolve(compressedBase64);
                            } catch (e) {
                                // Fallback directly to original read base64 if canvas is restricted
                                resolve(event.target.result);
                            }
                        };
                        img.onerror = () => {
                            // Fallback directly to original read base64 if image initialization fails
                            resolve(event.target.result);
                        };
                        img.src = event.target.result;
                    };
                    reader.onerror = (err) => reject(err);
                    reader.readAsDataURL(file);
                });
            };

            const handlePhotoInputChange = async (e, callback) => {
                const file = e.target.files[0];
                if (!file) return;

                try {
                    triggerToast("📸 正在进行照片无损画布级压缩...", "success");
                    const compressedDataUrl = await compressPhoto(file);
                    callback(compressedDataUrl);
                    triggerToast("照片优化压缩成功！", "success");
                } catch (error) {
                    console.error("照片压缩失败:", error);
                    triggerToast("照片处理失败，请重试", "error");
                }
            };

            const handleTrueIntelligentImport = async () => {
                const queryStr = linkToImport.trim();
                if (!queryStr) {
                    triggerToast("请先输入模糊描述、手办名或粘贴商品分享链接", "error");
                    return;
                }

                setIsParsingLink(true);
                triggerToast("⚡ Gemini 联网解析中，正在全网搜索最合理的行情估价...", "success");

                try {
                    const systemPrompt = `You are a professional appraisal bot for pop culture toys, blindboxes, and collectibles (e.g. Pop Mart, Bearbrick, Pokémon, Hot Toys). 
                    Analyze the user query/link and search the internet using Google Search to get the exact name, character, IP, average second-hand market price in Chinese Yuan (RMB) and tags. 
                    Respond STRICTLY with a valid JSON object matching this schema. Do not output markdown code blocks.
                    JSON Schema:
                    {
                        "name": "Exact item name in Chinese",
                        "ip": "The brand or company name in Chinese (e.g., 泡泡玛特, 积木熊, 宝可梦, 任天堂, 乐高)",
                        "character": "Main character name",
                        "purchase_price": 59,
                        "current_market_price": 350,
                        "tags": ["Tag1", "Tag2"],
                        "notes": "A brief artistic description in Chinese including second-hand market dynamics (e.g. 闲鱼/得物行情)."
                    }`;

                    const payload = {
                        contents: [{ parts: [{ text: `Search for details & prices: ${queryStr}` }] }],
                        tools: [{ "google_search": {} }],
                        systemInstruction: {
                            parts: [{ text: systemPrompt }]
                        },
                        generationConfig: {
                            responseMimeType: "application/json"
                        }
                    };

                    const apiKey = ""; // System dynamically feeds token at runtime
                    const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;

                    const response = await fetch(apiUrl, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(payload)
                    });

                    if (!response.ok) {
                        throw new Error("Gemini API 请求异常");
                    }

                    const jsonResult = await response.json();
                    const parsedText = jsonResult.candidates?.[0]?.content?.parts?.[0]?.text;
                    const parsedData = JSON.parse(parsedText);

                    setFormName(parsedData?.name || queryStr);
                    setFormIp(parsedData?.ip || "其他");
                    setFormCharacter(parsedData?.character || "通用");
                    setFormTags(Array.isArray(parsedData?.tags) ? parsedData.tags.join(", ") : "");
                    setFormPurchasePrice(parsedData?.purchase_price || "");
                    setFormCurrentMarketPrice(parsedData?.current_market_price || "");
                    setFormNotes(parsedData?.notes || "");
                    
                    if (parsedData?.ip && !customIPs.includes(parsedData.ip)) {
                        setCustomIPs(prev => [...prev, parsedData.ip]);
                    }

                    triggerToast("✨ 联网元数据抓取填充成功！可进行二次编辑或直接保存！");
                } catch (err) {
                    console.error(err);
                    setFormName(queryStr);
                    setFormIp("其他");
                    setFormCharacter("通用");
                    setFormNotes(`[本地快照分析] 自动为【${queryStr}】建立基础馆藏卡。`);
                    triggerToast("网络连接受限，已自动为您建立基础馆藏档", "success");
                } finally {
                    setIsParsingLink(false);
                }
            };

            useEffect(() => {
                safeSetLocalStorage("vibe_museum_items", items);
            }, [items]);

            useEffect(() => {
                safeSetLocalStorage("vibe_custom_ips", customIPs);
            }, [customIPs]);

            const currentItem = useMemo(() => {
                return items.find(i => i.id === selectedItemId) || null;
            }, [items, selectedItemId]);

            const filteredItems = useMemo(() => {
                return items.filter(item => {
                    const name = item?.name || "";
                    const character = item?.character || "";
                    const notes = item?.notes || "";
                    const tags = Array.isArray(item?.tags) ? item.tags : [];

                    const matchesSearch = name.toLowerCase().includes(searchQuery.toLowerCase()) || 
                                          character.toLowerCase().includes(searchQuery.toLowerCase()) ||
                                          notes.toLowerCase().includes(searchQuery.toLowerCase()) ||
                                          tags.some(t => t.toLowerCase().includes(searchQuery.toLowerCase()));
                    
                    const matchesIP = selectedIP === "全部" || item.ip === selectedIP;
                    return matchesSearch && matchesIP;
                });
            }, [items, searchQuery, selectedIP]);

            // High Fidelity Stats Dashboard restored per user's requests with unrealized calculation
            const stats = useMemo(() => {
                let totalCost = 0;
                let currentEstimatedVal = 0;
                let realizedGain = 0;
                let activeCount = 0;

                items.forEach(item => {
                    const purchase = Number(item?.purchase_price) || 0;
                    const market = Number(item?.current_market_price) || 0;
                    if (item.status === "sold") {
                        realizedGain += (market - purchase);
                    } else {
                        totalCost += purchase;
                        currentEstimatedVal += market;
                        activeCount++;
                    }
                });

                const unrealizedGain = currentEstimatedVal - totalCost;

                return {
                    totalCost,
                    currentEstimatedVal,
                    realizedGain,
                    unrealizedGain,
                    activeCount
                };
            }, [items]);

            useEffect(() => {
                if (activeTab === "add") {
                    if (editingItem) {
                        setFormName(editingItem.name || "");
                        setFormIp(editingItem.ip || "其他");
                        setFormCharacter(editingItem.character || "通用");
                        setFormTags(editingItem.tags ? editingItem.tags.join(", ") : "");
                        setFormStatus(editingItem.status || "in_stock");
                        setFormImageUrl(editingItem.image_url || "");
                        setFormPurchasePrice(editingItem.purchase_price || "");
                        setFormCurrentMarketPrice(editingItem.current_market_price || "");
                        setFormLocationName(editingItem.location?.name || "");
                        setFormLocationDescription(editingItem.location?.description || "");
                        setFormLocationImageUrl(editingItem.location?.image_url || "");
                        setFormNotes(editingItem.notes || "");
                    } else {
                        setFormName("");
                        setFormIp("");
                        setFormCharacter("");
                        setFormTags("");
                        setFormStatus("in_stock");
                        setFormImageUrl("");
                        setFormPurchasePrice("");
                        setFormCurrentMarketPrice("");
                        setFormLocationName("");
                        setFormLocationDescription("");
                        setFormLocationImageUrl("");
                        setFormNotes("");
                    }
                    setLinkToImport(""); 
                }
            }, [activeTab, editingItem]);

            const executeDeleteItem = (id) => {
                setItems(prev => prev.filter(item => item.id !== id));
                setActiveTab("gallery");
                setSelectedItemId(null);
                setDeleteConfirmId(null);
                triggerToast("该物品已下架并从收藏馆完全删除。");
            };

            const updateItemStatus = (id, newStatus) => {
                setItems(prev => prev.map(item => {
                    if (item.id === id) {
                        return { ...item, status: newStatus };
                    }
                    return item;
                }));
                const statusLabel = newStatus === "sold" ? "已售出" : "在售中";
                triggerToast(`已将藏品变更为【${statusLabel}】`);
            };

            const handleDeepSeekValuation = async (item) => {
                setIsEvaluating(true);
                setValuationMessage("正在连接 Gemini 全球二级市场行情，拉取最新溢价估值...");
                
                try {
                    const systemPrompt = "You are a professional collectible valuer. Given the item details, return strictly JSON format: {\"estimated_price\": 120, \"reason\": \"Chinese explanation\"}";
                    const payload = {
                        contents: [{ parts: [{ text: `Current market price for: IP=${item.ip}, Name=${item.name}, Character=${item.character}` }] }],
                        tools: [{ "google_search": {} }],
                        systemInstruction: { parts: [{ text: systemPrompt }] },
                        generationConfig: { responseMimeType: "application/json" }
                    };

                    const apiKey = "";
                    const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;

                    const response = await fetch(apiUrl, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(payload)
                    });

                    if(!response.ok) throw new Error();

                    const res = await response.json();
                    const text = res.candidates?.[0]?.content?.parts?.[0]?.text;
                    const parsed = JSON.parse(text);

                    const newPrice = Number(parsed.estimated_price);
                    const updatedHistory = [...(Array.isArray(item.price_history) ? item.price_history : []), {
                        date: new Date().toISOString().split('T')[0],
                        price: newPrice,
                        source: "AI智能估价"
                    }];

                    setItems(prev => prev.map(i => i.id === item.id ? {
                        ...i,
                        current_market_price: newPrice,
                        price_history: updatedHistory,
                        notes: i.notes + `\n[AI估值分析]: ${parsed.reason}`
                    } : i));

                    triggerToast(`最新行情价为：¥${newPrice}`);
                } catch {
                    const fluctuation = (Math.random() * 0.3 - 0.1) * item.current_market_price;
                    const newEstimate = Math.max(item.purchase_price * 0.8, Math.round(item.current_market_price + fluctuation));
                    
                    const updatedPriceHistory = [...(Array.isArray(item.price_history) ? item.price_history : []), {
                        date: new Date().toISOString().split('T')[0],
                        price: newEstimate,
                        source: "智能估价 (模拟)"
                    }];

                    setItems(prev => prev.map(i => i.id === item.id ? {
                        ...i,
                        current_market_price: newEstimate,
                        price_history: updatedPriceHistory
                    } : i));
                    triggerToast(`最新行情估值结果为：¥${newEstimate}`);
                } finally {
                    setIsEvaluating(false);
                    setValuationMessage("");
                }
            };

            return (
                <div className="max-w-md mx-auto min-h-screen bg-[#f6f6f3] shadow-xl relative flex flex-col pt-safe pb-safe pb-24 animate-fade-in">
                    
                    {/* Custom elegant Toast Banner */}
                    {toast && (
                        <div className="fixed top-6 left-1/2 -translate-x-1/2 w-[90%] max-w-sm z-50 animate-bounce">
                            <div className={`p-4 rounded-2xl shadow-xl border flex items-center gap-3 ${toast.type === "success" ? "bg-[#20252c] text-[#fbfbfa] border-[#3e4550]" : "bg-rose-50 text-rose-900 border-rose-200"}`}>
                                <Icon name="sparkles" className={`w-5 h-5 ${toast.type === "success" ? "text-amber-400" : "text-rose-600"}`} />
                                <span className="text-xs font-semibold leading-snug">{toast.msg}</span>
                            </div>
                        </div>
                    )}

                    {/* Custom confirmation popup */}
                    {deleteConfirmId && (
                        <div className="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center p-6 z-50">
                            <div className="bg-white rounded-3xl p-6 w-full max-w-xs text-center space-y-4 shadow-2xl border border-neutral-100">
                                <h3 className="text-sm font-bold text-[#20252c] serif-font">确定彻底从馆藏中删除？</h3>
                                <p className="text-xs text-neutral-400 leading-relaxed">
                                    此下架操作将清除该宝贝所有历史和影像，无法撤回。
                                </p>
                                <div className="grid grid-cols-2 gap-3 pt-2">
                                    <button 
                                        onClick={() => setDeleteConfirmId(null)}
                                        className="py-2.5 bg-neutral-100 text-neutral-600 text-xs font-semibold rounded-xl"
                                    >
                                        取消
                                    </button>
                                    <button 
                                        onClick={() => executeDeleteItem(deleteConfirmId)}
                                        className="py-2.5 bg-rose-600 text-white text-xs font-semibold rounded-xl hover:bg-rose-700"
                                    >
                                        确定下架删除
                                    </button>
                                </div>
                            </div>
                        </div>
                    )}

                    {/* GALLERY TAB */}
                    {activeTab === "gallery" && (
                        <div className="flex-1 flex flex-col">
                            {/* Dashboard header card */}
                            <div className="px-6 py-4 flex justify-between items-end">
                                <div>
                                    <span className="text-[10px] tracking-widest text-[#9c9c92] block uppercase font-mono">Personal Vault / </span>
                                    <h2 className="text-3xl font-extrabold text-[#20252c] serif-font">Vibe 馆</h2>
                                </div>
                                <div className="text-right font-mono">
                                    <span className="text-[10px] text-neutral-400 block">当前馆藏数量</span>
                                    <span className="text-lg font-bold">{stats.activeCount} 件</span>
                                </div>
                            </div>

                            {/* PREMIUM HEADER DATA PANEL (RESTORED AS REQUESTED) */}
                            <div className="px-6 mb-4">
                                <div className="bg-[#1a1a1a] text-[#fbfbfa] rounded-3xl p-5 shadow-sm relative overflow-hidden">
                                    <div className="absolute right-[-20px] bottom-[-20px] opacity-10 text-white font-bold text-8xl pointer-events-none serif-font">
                                        M
                                    </div>
                                    <div className="flex justify-between items-center mb-4">
                                        <span className="text-xs uppercase tracking-wider opacity-60">馆内资产估值</span>
                                        <span className="px-2.5 py-0.5 bg-white/20 rounded-full text-[10px] uppercase font-mono tracking-wider">
                                            LIVE ESTIMATION
                                        </span>
                                    </div>
                                    <div className="flex items-baseline mb-2">
                                        <span className="text-3xl font-bold serif-font">¥{(stats.currentEstimatedVal).toLocaleString()}</span>
                                        <span className="text-xs ml-2 opacity-70">总市值估算</span>
                                    </div>
                                    <div className="grid grid-cols-3 gap-2 pt-3 border-t border-white/10 text-xs">
                                        <div>
                                            <p className="opacity-50 text-[10px]">购入成本</p>
                                            <p className="font-mono font-medium">¥{stats.totalCost}</p>
                                        </div>
                                        <div>
                                            <p className="opacity-50 text-[10px]">未变现盈亏</p>
                                            <p className={`font-mono font-medium ${stats.unrealizedGain >= 0 ? "text-emerald-400" : "text-rose-400"}`}>
                                                {stats.unrealizedGain >= 0 ? "+" : ""}¥{stats.unrealizedGain}
                                            </p>
                                        </div>
                                        <div>
                                            <p className="opacity-50 text-[10px]">已套现净利</p>
                                            <p className="font-mono font-medium text-emerald-400">¥{stats.realizedGain}</p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            {/* Search and Filters */}
                            <div className="space-y-3">
                                <div className="px-6 relative flex items-center">
                                    <input 
                                        type="text" 
                                        placeholder="搜寻馆藏、角色或标签..."
                                        value={searchQuery}
                                        onChange={(e) => setSearchQuery(e.target.value)}
                                        className="w-full pl-10 pr-4 py-2.5 bg-white border border-[#e5e5e0] rounded-xl text-sm focus:outline-none focus:border-neutral-500 transition shadow-inner"
                                    />
                                    <div className="absolute left-9 text-neutral-400">
                                        <Icon name="search" className="w-4 h-4" />
                                    </div>
                                </div>

                                {/* Custom IP Filters with Drag Scrolling */}
                                <div className="relative">
                                    <div className="absolute left-0 top-0 bottom-0 w-8 bg-gradient-to-r from-[#f6f6f3] to-transparent pointer-events-none z-10"></div>
                                    <div 
                                        ref={scrollContainerRef}
                                        onMouseDown={handleMouseDown}
                                        onMouseLeave={handleMouseLeave}
                                        onMouseUp={handleMouseUp}
                                        onMouseMove={handleMouseMove}
                                        className="flex overflow-x-auto gap-2 no-scrollbar py-1.5 px-6 scroll-smooth select-none cursor-grab active:cursor-grabbing"
                                    >
                                        {customIPs.map(ip => (
                                            <button
                                                key={ip}
                                                onClick={() => { setSelectedIP(ip); setSelectedCharacter("全部"); }}
                                                className={`px-4 py-1.5 rounded-full text-xs font-semibold whitespace-nowrap transition-all duration-200 border ${
                                                    selectedIP === ip 
                                                        ? "bg-[#20252c] text-white border-transparent shadow-sm scale-95" 
                                                        : "bg-white text-[#20252c] border-[#e5e5e0] hover:border-neutral-400 active:scale-95"
                                                }`}
                                            >
                                                {ip}
                                            </button>
                                        ))}
                                    </div>
                                    <div className="absolute right-0 top-0 bottom-0 w-8 bg-gradient-to-l from-[#f6f6f3] to-transparent pointer-events-none z-10"></div>
                                </div>
                            </div>

                            {/* Grid Layout */}
                            <div className="px-6 py-4 flex-1">
                                {filteredItems.length === 0 ? (
                                    <div className="bg-white border border-dashed border-[#e5e5e0] rounded-3xl p-8 text-center text-[#8c8c82]">
                                        <p className="text-sm">未搜寻到匹配该标签的精美馆藏。</p>
                                        <button 
                                            onClick={() => setActiveTab("add")}
                                            className="mt-3 inline-flex items-center gap-1 text-xs text-[#20252c] underline font-semibold"
                                        >
                                            立即开辟新馆藏
                                        </button>
                                    </div>
                                ) : (
                                    <div className="grid grid-cols-2 gap-4">
                                        {filteredItems.map(item => {
                                            const purchase = Number(item?.purchase_price) || 0;
                                            const market = Number(item?.current_market_price) || 0;
                                            const profitRate = purchase > 0 ? ((market - purchase) / purchase) * 100 : 0;
                                            const isSold = item.status === "sold";
                                            const isSelling = item.status === "selling";

                                            return (
                                                <div 
                                                    key={item.id}
                                                    onClick={() => { setSelectedItemId(item.id); setActiveTab("detail"); }}
                                                    className="bg-white rounded-3xl overflow-hidden border border-[#e5e5e0] hover:border-neutral-400 transition cursor-pointer flex flex-col justify-between"
                                                >
                                                    <div className="relative aspect-square overflow-hidden bg-neutral-100">
                                                        {item.image_url ? (
                                                            <img 
                                                                src={item.image_url} 
                                                                alt={item.name}
                                                                className={`w-full h-full object-cover transition-transform duration-500 hover:scale-105 ${isSold ? "sold-out-grayscale" : ""}`}
                                                            />
                                                        ) : (
                                                            <ImageFallback title={item.name} />
                                                        )}
                                                        {isSold && (
                                                            <div className="absolute inset-0 bg-black/25 flex items-center justify-center">
                                                                <span className="px-3 py-1 bg-white/95 text-[10px] font-bold tracking-widest text-[#20252c] rounded-full uppercase">
                                                                    已售 / SOLD
                                                                </span>
                                                            </div>
                                                        )}
                                                        {isSelling && (
                                                            <div className="absolute top-2 left-2 bg-[#f0effa] text-[#5244ad] text-[9px] font-semibold px-2 py-0.5 rounded-full uppercase tracking-wider flex items-center gap-0.5">
                                                                <span>🛒</span> 寻主中
                                                            </div>
                                                        )}
                                                        {!isSold && profitRate >= 45 && (
                                                            <div className="absolute top-2 right-2 bg-rose-500 text-white text-[9px] font-bold px-2 py-0.5 rounded-full flex items-center gap-0.5 animate-pulse">
                                                                🔥 宜出手
                                                            </div>
                                                        )}
                                                    </div>

                                                    <div className="p-3.5 space-y-1">
                                                        <span className="text-[10px] text-neutral-400 font-mono tracking-wider block uppercase">
                                                            {item.ip} · {item.character}
                                                        </span>
                                                        <h3 className="text-xs font-bold text-[#20252c] line-clamp-1 leading-tight">
                                                            {item.name}
                                                        </h3>
                                                        <div className="flex justify-between items-baseline pt-1">
                                                            <span className="text-xs font-bold">¥{market}</span>
                                                            <span className="text-[10px] font-mono text-[#8c8c82]">
                                                                购入: ¥{purchase}
                                                            </span>
                                                        </div>
                                                    </div>
                                                </div>
                                            );
                                        })}
                                    </div>
                                )}
                            </div>
                        </div>
                    )}

                    {/* DETAIL TAB */}
                    {activeTab === "detail" && currentItem && (
                        <div className="flex-1 bg-white">
                            <div className="relative w-full aspect-[4/5] bg-neutral-100">
                                {currentItem.image_url ? (
                                    <img 
                                        src={currentItem.image_url} 
                                        alt={currentItem.name}
                                        className={`w-full h-full object-cover ${currentItem.status === "sold" ? "sold-out-grayscale" : ""}`}
                                    />
                                ) : (
                                    <ImageFallback title={currentItem.name} className="w-full h-full" />
                                )}
                                <div className="absolute top-4 left-4 right-4 flex justify-between items-center">
                                    <button 
                                        onClick={() => setActiveTab("gallery")} 
                                        className="p-2 bg-white/95 rounded-full text-[#20252c] shadow-md hover:bg-white"
                                    >
                                        <Icon name="back" className="w-5 h-5" />
                                    </button>
                                    <div className="flex gap-2">
                                        <button 
                                            onClick={() => { setEditingItem(currentItem); setActiveTab("add"); }} 
                                            className="p-2 bg-white/95 rounded-full text-[#20252c] shadow-md hover:bg-white"
                                        >
                                            <Icon name="edit" className="w-5 h-5" />
                                        </button>
                                        <button 
                                            onClick={() => setDeleteConfirmId(currentItem.id)} 
                                            className="p-2 bg-white/95 rounded-full text-rose-600 shadow-md hover:bg-white"
                                        >
                                            <Icon name="trash" className="w-5 h-5" />
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div className="px-6 py-6 space-y-6">
                                <div>
                                    <span className="text-xs tracking-widest font-mono text-[#8c8c82] uppercase">{currentItem.ip || "其他"} IP 藏品</span>
                                    <h2 className="text-2xl font-bold serif-font text-[#20252c] mt-1 leading-snug">{currentItem.name}</h2>
                                    <p className="text-sm italic text-neutral-500">角色系列: {currentItem.character || "通用"}</p>
                                </div>

                                <div className="p-4 bg-neutral-50 border border-[#e5e5e0] rounded-2xl space-y-3">
                                    <h3 className="text-xs font-bold uppercase tracking-wider text-neutral-400">快速状态变更</h3>
                                    <div className="grid grid-cols-2 gap-2">
                                        <button 
                                            onClick={() => updateItemStatus(currentItem.id, "selling")}
                                            className={`py-2 px-3 rounded-xl border text-[11px] font-semibold flex items-center justify-center gap-1 ${currentItem.status === 'selling' ? 'bg-[#5244ad] text-[#fbfbfa] border-transparent' : 'bg-white border-[#e5e5e0] text-[#20252c]'}`}
                                        >
                                            <span>🛒</span> 设为在售中
                                        </button>
                                        <button 
                                            onClick={() => updateItemStatus(currentItem.id, "sold")}
                                            className={`py-2 px-3 rounded-xl border text-[11px] font-semibold flex items-center justify-center gap-1 ${currentItem.status === 'sold' ? 'bg-[#20252c] text-[#fbfbfa] border-transparent' : 'bg-white border-[#e5e5e0] text-[#20252c]'}`}
                                        >
                                            <span>💰</span> 设为已售出
                                        </button>
                                        <button 
                                            onClick={() => setDeleteConfirmId(currentItem.id)}
                                            className="py-2 px-3 rounded-xl border border-red-200 bg-red-50 text-red-700 text-[11px] font-semibold flex items-center justify-center gap-1 col-span-2"
                                        >
                                            <Icon name="trash" className="w-3.5 h-3.5 text-red-600" />
                                            一键下架（彻底从馆藏中删除）
                                        </button>
                                    </div>
                                </div>

                                <div className="border-t border-b border-[#e5e5e0] py-4 grid grid-cols-2 gap-y-3 gap-x-4 text-xs font-mono">
                                    <div className="flex justify-between pr-4 border-r border-[#f0f0e8]">
                                        <span className="text-neutral-400">目前状态</span>
                                        <span className="font-semibold text-[#20252c]">
                                            {currentItem.status === "in_stock" ? "在馆中" : currentItem.status === "selling" ? "上架寻主" : "已出手(黑白档)"}
                                        </span>
                                    </div>
                                    <div className="flex justify-between pl-2">
                                        <span className="text-neutral-400">建档时间</span>
                                        <span className="font-semibold text-[#20252c]">{currentItem.created_at || "2026-06-10"}</span>
                                    </div>
                                    <div className="flex justify-between pr-4 border-r border-[#f0f0e8]">
                                        <span className="text-neutral-400">入手原价</span>
                                        <span className="font-semibold text-[#20252c]">¥{Number(currentItem.purchase_price) || 0}</span>
                                    </div>
                                    <div className="flex justify-between pl-2">
                                        <span className="text-neutral-400">最新评估价</span>
                                        <span className="font-semibold text-[#20252c]">¥{Number(currentItem.current_market_price) || 0}</span>
                                    </div>
                                    <div className="flex justify-between pr-4 border-r border-[#f0f0e8]">
                                        <span className="text-neutral-400">投资回报比</span>
                                        <span className={`font-semibold ${currentItem.current_market_price >= currentItem.purchase_price ? "text-emerald-600" : "text-rose-600"}`}>
                                            {currentItem.purchase_price > 0 ? (((currentItem.current_market_price - currentItem.purchase_price) / currentItem.purchase_price) * 100).toFixed(0) : 0}%
                                        </span>
                                    </div>
                                    <div className="flex justify-between pl-2 relative">
                                        <span className="text-neutral-400">实体存放</span>
                                        <button 
                                            onClick={() => setShowLocationPopover(!showLocationPopover)}
                                            className="font-semibold text-[#20252c] underline flex items-center gap-0.5 cursor-pointer"
                                        >
                                            <Icon name="location" className="w-3.5 h-3.5 text-neutral-500" />
                                            {currentItem.location?.name || "未归类"}
                                        </button>
                                    </div>
                                </div>

                                {showLocationPopover && (
                                    <div className="bg-[#fcfcf9] border border-[#e5e5e0] rounded-2xl p-4 space-y-3 shadow-md">
                                        <div className="flex justify-between items-center">
                                            <h4 className="text-xs font-bold uppercase tracking-wider text-neutral-500">实体柜位置导航</h4>
                                            <button onClick={() => setShowLocationPopover(false)} className="text-xs text-[#8c8c82]">关闭</button>
                                        </div>
                                        {currentItem.location?.image_url && (
                                            <div className="w-full aspect-[16/9] rounded-xl overflow-hidden bg-neutral-100">
                                                <img 
                                                    src={currentItem.location.image_url} 
                                                    alt="柜位实拍" 
                                                    className="w-full h-full object-cover"
                                                />
                                            </div>
                                        )}
                                        <div className="space-y-1">
                                            <p className="text-xs font-semibold text-[#20252c]">{currentItem.location?.name}</p>
                                            <p className="text-xs text-[#8c8c82] leading-relaxed">
                                                {currentItem.location?.description || "暂未填写具体的视觉引导描述。"}
                                            </p>
                                        </div>
                                    </div>
                                )}

                                {/* Price charts */}
                                <div className="space-y-3">
                                    <div className="flex justify-between items-center">
                                        <h3 className="text-xs uppercase tracking-wider font-semibold text-neutral-400">AI 行情估算与曲线</h3>
                                        <button 
                                            onClick={() => handleDeepSeekValuation(currentItem)}
                                            disabled={isEvaluating}
                                            className="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gradient-to-r from-[#1a1a1a] to-[#3a3a3a] text-white text-xs font-semibold rounded-full hover:shadow-md transition disabled:opacity-55"
                                        >
                                            <Icon name="sparkles" className="w-3.5 h-3.5" />
                                            {isEvaluating ? "正在估算..." : "DeepSeek 估价"}
                                        </button>
                                    </div>

                                    {isEvaluating && (
                                        <div className="p-3 bg-neutral-50 border border-neutral-200 rounded-xl shimmer text-xs text-neutral-600 leading-relaxed">
                                            {valuationMessage}
                                        </div>
                                    )}

                                    <PriceTrendChart 
                                        history={currentItem.price_history} 
                                        purchasePrice={Number(currentItem.purchase_price) || 0}
                                        currentPrice={Number(currentItem.current_market_price) || 0}
                                    />
                                </div>

                                <div className="space-y-2">
                                    <h3 className="text-xs uppercase tracking-wider font-semibold text-neutral-400">品类赏析 / 备注</h3>
                                    <p className="text-sm text-[#20252c] leading-relaxed serif-font">
                                        {currentItem.notes || "主理人很懒，尚未为此藏品撰写艺术赏析语录。"}
                                    </p>
                                </div>

                                {/* Tags */}
                                <div className="flex flex-wrap gap-1.5 pt-2">
                                    {(Array.isArray(currentItem.tags) ? currentItem.tags : []).map((tag, idx) => (
                                        <span key={idx} className="bg-neutral-100 text-neutral-600 text-[10px] px-2.5 py-1 rounded-full uppercase font-medium">
                                            #{tag}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        </div>
                    )}

                    {/* ADD/EDIT FORM TAB */}
                    {activeTab === "add" && (
                        <div className="p-6 bg-white flex-1 space-y-6">
                            <div className="flex justify-between items-center">
                                <h2 className="text-xl font-bold serif-font text-[#20252c]">
                                    {editingItem ? "调整馆藏档案" : "录入珍藏佳作"}
                                </h2>
                                <button 
                                    onClick={() => { setEditingItem(null); setActiveTab(editingItem ? "detail" : "gallery"); }} 
                                    className="text-xs text-[#8c8c82] uppercase tracking-wider"
                                >
                                    取消
                                </button>
                            </div>

                            {/* Truly Intelligent Auto-Importer */}
                            {!editingItem && (
                                <div className="p-4 bg-[#fcfcf9] border border-[#e5e5e0] rounded-2xl space-y-3 shadow-inner">
                                    <div className="flex items-center gap-2">
                                        <div className="p-1 bg-[#1a1a1a] text-[#f6f6f3] rounded-lg">
                                            <Icon name="sparkles" className="w-4 h-4 text-amber-400" />
                                        </div>
                                        <span className="text-xs font-bold text-[#20252c]">✨ Gemini 联网搜索与智能解析</span>
                                    </div>
                                    <p className="text-[10px] text-neutral-400 leading-relaxed">
                                        输入商品模糊名、手办描述，或者粘贴闲鱼/得物/天猫的商品分享链接。Gemini 将实时为您检索市场行情并全自动为您填表。
                                    </p>
                                    
                                    {/* API KEY WARNING BANNER (ADDED PER USER'S REQUIREMENT) */}
                                    <div className="p-3 bg-amber-50 border border-amber-200/50 rounded-xl text-amber-800 text-[10px] leading-relaxed flex items-start gap-1.5">
                                        <span className="mt-0.5">⚠️</span>
                                        <p>
                                            <strong>重要提醒：</strong>智能联网估价与数据提取基于大语言模型。请在 <strong>系统配置</strong> 中接入密钥（或点击右上角设置）后才能调用真实的分析数据。未填时将自动降级为本地快速模拟建档。
                                        </p>
                                    </div>

                                    <div className="flex gap-2">
                                        <input 
                                            type="text" 
                                            placeholder="如：得物上molly蒸汽朋克多少钱..."
                                            value={linkToImport}
                                            onChange={(e) => setLinkToImport(e.target.value)}
                                            className="flex-1 px-3 py-2 bg-white border border-[#e5e5e0] rounded-xl text-xs focus:outline-none"
                                        />
                                        <button 
                                            type="button"
                                            onClick={handleTrueIntelligentImport}
                                            disabled={isParsingLink}
                                            className="px-4 py-2 bg-[#20252c] text-white text-xs font-semibold rounded-xl hover:bg-neutral-800 disabled:opacity-55 transition whitespace-nowrap"
                                        >
                                            {isParsingLink ? "联网检索中..." : "联网解析"}
                                        </button>
                                    </div>
                                </div>
                            )}

                            <form onSubmit={(e) => {
                                e.preventDefault();
                                const tagsArray = formTags.split(/[,，]/).map(t => t.trim()).filter(Boolean);
                                const inputIP = formIp.trim() || "其他";

                                if (inputIP && !customIPs.includes(inputIP)) {
                                    setCustomIPs(prev => [...prev, inputIP]);
                                }

                                const updatedItem = {
                                    id: editingItem ? editingItem.id : "item-" + Date.now(),
                                    name: formName,
                                    ip: inputIP,
                                    character: formCharacter || "通用",
                                    tags: tagsArray,
                                    status: formStatus,
                                    image_url: formImageUrl,
                                    purchase_price: Number(formPurchasePrice) || 0,
                                    current_market_price: Number(formCurrentMarketPrice) || 0,
                                    price_history: editingItem 
                                        ? [
                                            ...(Array.isArray(editingItem.price_history) ? editingItem.price_history : []),
                                            {
                                                date: new Date().toISOString().split('T')[0],
                                                price: Number(formCurrentMarketPrice) || 0,
                                                source: "更新价格"
                                            }
                                          ].filter((v, i, self) => self.findIndex(t => t.date === v.date && t.price === v.price) === i) 
                                        : [
                                            {
                                                date: new Date().toISOString().split('T')[0],
                                                price: Number(formPurchasePrice) || 0,
                                                source: "入手价"
                                            },
                                            {
                                                date: new Date().toISOString().split('T')[0],
                                                price: Number(formCurrentMarketPrice) || 0,
                                                source: "录入估价"
                                            }
                                        ],
                                    location: {
                                        name: formLocationName || "未分类",
                                        description: formLocationDescription || "",
                                        image_url: formLocationImageUrl
                                    },
                                    created_at: editingItem ? editingItem.created_at : new Date().toISOString().split('T')[0],
                                    notes: formNotes
                                };

                                if (editingItem) {
                                    setItems(prev => prev.map(i => i.id === editingItem.id ? updatedItem : i));
                                    triggerToast("档案已成功保存微调。");
                                } else {
                                    setItems(prev => [updatedItem, ...prev]);
                                    triggerToast("新藏品已完美收录入库！");
                                }

                                setEditingItem(null);
                                setActiveTab("gallery");
                            }} className="space-y-4 text-xs font-medium text-[#20252c]">
                                
                                <div className="space-y-1.5">
                                    <label className="text-neutral-500 block uppercase tracking-wider text-[10px]">藏品实体照片 (选填)</label>
                                    <div className="flex gap-3 items-center">
                                        <div className="w-16 h-16 rounded-xl border border-dashed border-[#e5e5e0] overflow-hidden bg-neutral-50 flex items-center justify-center relative cursor-pointer">
                                            <input 
                                                type="file" 
                                                accept="image/*" 
                                                onChange={(e) => handlePhotoInputChange(e, setFormImageUrl)}
                                                className="absolute inset-0 opacity-0 cursor-pointer"
                                            />
                                            {formImageUrl ? (
                                                <img 
                                                    src={formImageUrl}
                                                    className="w-full h-full object-cover pointer-events-none" 
                                                />
                                            ) : (
                                                <span className="text-xl text-neutral-400">+</span>
                                            )}
                                        </div>
                                        <div className="text-[10px] text-neutral-400 leading-relaxed">
                                            支持手机直接拍照或相册直传。<b>已开启高保真无损压缩机制</b>，照片上传也绝不裂图。如不上传则默认极简画展框。
                                        </div>
                                    </div>
                                </div>

                                <div className="space-y-1">
                                    <label className="text-neutral-500 block uppercase tracking-wider text-[10px]">藏品商品名称 <span className="text-rose-500">*</span></label>
                                    <input 
                                        type="text" 
                                        value={formName}
                                        onChange={(e) => setFormName(e.target.value)}
                                        placeholder="请输入藏品名称（唯一强制必填）"
                                        required
                                        className="w-full px-3 py-2 bg-white border border-[#e5e5e0] rounded-xl focus:outline-none"
                                    />
                                </div>

                                <div className="grid grid-cols-2 gap-4">
                                    <div className="space-y-1">
                                        <label className="text-neutral-500 block uppercase tracking-wider text-[10px]">所属大类 IP (支持手输/选填)</label>
                                        <input 
                                            type="text"
                                            value={formIp}
                                            onChange={(e) => setFormIp(e.target.value)}
                                            list="ip-options"
                                            placeholder="如: 泡泡玛特 / 任天堂"
                                            className="w-full px-3 py-2 bg-white border border-[#e5e5e0] rounded-xl focus:outline-none"
                                        />
                                        <datalist id="ip-options">
                                            {customIPs.filter(ip => ip !== "全部").map(ip => (
                                                <option key={ip} value={ip} />
                                            ))}
                                        </datalist>
                                    </div>
                                    <div className="space-y-1">
                                        <label className="text-neutral-500 block uppercase tracking-wider text-[10px]">角色 / 规格特征 (选填)</label>
                                        <input 
                                            type="text" 
                                            value={formCharacter}
                                            onChange={(e) => setFormCharacter(e.target.value)}
                                            placeholder="如: Molly"
                                            className="w-full px-3 py-2 bg-white border border-[#e5e5e0] rounded-xl focus:outline-none"
                                        />
                                    </div>
                                </div>

                                <div className="grid grid-cols-2 gap-4">
                                    <div className="space-y-1">
                                        <label className="text-neutral-500 block uppercase tracking-wider text-[10px]">入手价格 (¥, 选填)</label>
                                        <input 
                                            type="number" 
                                            value={formPurchasePrice}
                                            onChange={(e) => setFormPurchasePrice(e.target.value)}
                                            placeholder="未填则为 0"
                                            className="w-full px-3 py-2 bg-white border border-[#e5e5e0] rounded-xl focus:outline-none"
                                        />
                                    </div>
                                    <div className="space-y-1">
                                        <label className="text-neutral-500 block uppercase tracking-wider text-[10px]">当前估算市值 (¥, 选填)</label>
                                        <input 
                                            type="number" 
                                            value={formCurrentMarketPrice}
                                            onChange={(e) => setFormCurrentMarketPrice(e.target.value)}
                                            placeholder="未填则为 0"
                                            className="w-full px-3 py-2 bg-white border border-[#e5e5e0] rounded-xl focus:outline-none"
                                        />
                                    </div>
                                </div>

                                <div className="grid grid-cols-2 gap-4">
                                    <div className="space-y-1">
                                        <label className="text-neutral-500 block uppercase tracking-wider text-[10px]">当前馆藏状态</label>
                                        <select 
                                            value={formStatus}
                                            onChange={(e) => setFormStatus(e.target.value)}
                                            className="w-full px-3 py-2 bg-white border border-[#e5e5e0] rounded-xl focus:outline-none hover:bg-neutral-50"
                                        >
                                            <option value="in_stock">在馆珍藏中 (In Stock)</option>
                                            <option value="selling">正在出清在售中 (Selling)</option>
                                            <option value="sold">已套现/转让 (Sold)</option>
                                        </select>
                                    </div>
                                    <div className="space-y-1">
                                        <label className="text-neutral-500 block uppercase tracking-wider text-[10px]">属性标签 (逗号或空格分隔, 选填)</label>
                                        <input 
                                            type="text" 
                                            value={formTags}
                                            onChange={(e) => setFormTags(e.target.value)}
                                            placeholder="限定款, 盲盒"
                                            className="w-full px-3 py-2 bg-white border border-[#e5e5e0] rounded-xl focus:outline-none"
                                        />
                                    </div>
                                </div>

                                <div className="border-t border-[#f0f0e8] pt-3 space-y-3">
                                    <h4 className="text-[10px] uppercase font-bold tracking-widest text-[#8c8c82]">实体定位信息 (可选)</h4>
                                    <div className="grid grid-cols-2 gap-4">
                                        <div className="space-y-1">
                                            <label className="text-neutral-500 block uppercase tracking-wider text-[10px]">物理位置名</label>
                                            <input 
                                                type="text" 
                                                value={formLocationName}
                                                onChange={(e) => setFormLocationName(e.target.value)}
                                                placeholder="例如: 客厅A柜第三层"
                                                className="w-full px-3 py-2 bg-white border border-[#e5e5e0] rounded-xl focus:outline-none"
                                            />
                                        </div>
                                        <div className="space-y-1">
                                            <label className="text-neutral-500 block uppercase tracking-wider text-[10px]">位置定位实拍照片</label>
                                            <div className="flex gap-2 items-center">
                                                <div className="w-8 h-8 rounded-lg border border-dashed border-[#e5e5e0] overflow-hidden bg-neutral-50 flex items-center justify-center relative">
                                                    <input 
                                                        type="file" 
                                                        accept="image/*" 
                                                        onChange={(e) => handlePhotoInputChange(e, setFormLocationImageUrl)}
                                                        className="absolute inset-0 opacity-0 cursor-pointer"
                                                    />
                                                    {formLocationImageUrl ? (
                                                        <img 
                                                            src={formLocationImageUrl}
                                                            className="w-full h-full object-cover pointer-events-none" 
                                                        />
                                                    ) : (
                                                        <span className="text-neutral-400">+</span>
                                                    )}
                                                </div>
                                                <span className="text-[9px] text-neutral-400">拍摄实存位置</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div className="space-y-1">
                                        <label className="text-neutral-500 block uppercase tracking-wider text-[10px]">方位描述</label>
                                        <input 
                                            type="text" 
                                            value={formLocationDescription}
                                            onChange={(e) => setFormLocationDescription(e.target.value)}
                                            placeholder="最里面靠左角落，放在高达身后"
                                            className="w-full px-3 py-2 bg-white border border-[#e5e5e0] rounded-xl focus:outline-none"
                                        />
                                    </div>
                                </div>

                                <div className="space-y-1">
                                    <label className="text-neutral-500 block uppercase tracking-wider text-[10px]">藏品品相及赏析备注 (选填)</label>
                                    <textarea 
                                        value={formNotes}
                                        onChange={(e) => setFormNotes(e.target.value)}
                                        placeholder="在这里写下对此艺术品的理解..."
                                        rows="3"
                                        className="w-full px-3 py-2 bg-white border border-[#e5e5e0] rounded-xl focus:outline-none resize-none"
                                    ></textarea>
                                </div>

                                <button 
                                    type="submit"
                                    className="w-full py-3 bg-[#20252c] text-white text-xs font-semibold rounded-xl hover:shadow-md transition mt-4"
                                >
                                    {editingItem ? "确认修改" : "确认录入档案"}
                                </button>
                            </form>
                        </div>
                    )}

                    {/* SETTINGS TAB */}
                    {activeTab === "settings" && (
                        <div className="p-6 bg-white flex-1 space-y-6">
                            <div className="flex justify-between items-center">
                                <h2 className="text-xl font-bold serif-font text-[#20252c]">系统与智能配置</h2>
                                <button onClick={() => setActiveTab("gallery")} className="text-xs text-[#8c8c82]">返回</button>
                            </div>

                            <div className="space-y-4">
                                <div className="p-4 bg-[#fcfcf9] border border-[#e5e5e0] rounded-2xl space-y-3">
                                    <div className="flex items-center gap-1.5">
                                        <Icon name="sparkles" className="w-5 h-5 text-neutral-800" />
                                        <span className="text-sm font-semibold text-[#20252c]">DeepSeek / Gemini API Key</span>
                                    </div>
                                    <p className="text-xs text-[#8c8c82] leading-relaxed">
                                        智能估价服务同时向 Gemini 行情大模型兼容。在此输入您个人的 API 密钥。
                                    </p>
                                    <div className="space-y-1.5">
                                        <input 
                                            type="password"
                                            placeholder="sk-xxxxxxxxxxxxxx"
                                            value={deepSeekKey}
                                            onChange={(e) => saveApiKey(e.target.value)}
                                            className="w-full px-3 py-2 bg-white border border-[#e5e5e0] rounded-xl text-xs font-mono focus:outline-none"
                                        />
                                    </div>
                                </div>

                                <div className="space-y-3">
                                    <h3 className="text-xs font-bold uppercase tracking-wider text-neutral-400">管理已存 IP 大类</h3>
                                    <div className="flex flex-wrap gap-2">
                                        {customIPs.filter(ip => ip !== "全部").map(ip => (
                                            <div key={ip} className="inline-flex items-center gap-1 bg-neutral-100 text-[#20252c] text-xs px-3 py-1.5 rounded-full">
                                                <span>{ip}</span>
                                                <button 
                                                    onClick={() => setCustomIPs(prev => prev.filter(p => p !== ip))}
                                                    className="text-neutral-400 hover:text-rose-600 text-[10px] font-bold"
                                                >
                                                    ×
                                                </button>
                                            </div>
                                        ))}
                                    </div>
                                </div>

                                <div className="border-t border-[#f0f0e8] pt-4 space-y-3 text-xs">
                                    <h3 className="text-xs font-bold uppercase tracking-wider text-neutral-400">馆藏数据备份</h3>
                                    <div className="grid grid-cols-2 gap-3">
                                        <button 
                                            onClick={() => {
                                                const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(items, null, 2));
                                                const downloadAnchor = document.createElement('a');
                                                downloadAnchor.setAttribute("href", dataStr);
                                                downloadAnchor.setAttribute("download", `Backup_${new Date().toISOString().split('T')[0]}.json`);
                                                document.body.appendChild(downloadAnchor);
                                                downloadAnchor.click();
                                                downloadAnchor.remove();
                                            }}
                                            className="py-2.5 bg-white border border-[#e5e5e0] text-[#20252c] rounded-xl font-semibold flex items-center justify-center gap-1.5"
                                        >
                                            <Icon name="share" className="w-4 h-4" />
                                            <span>导出备份</span>
                                        </button>
                                        <label className="py-2.5 bg-white border border-[#e5e5e0] text-[#20252c] rounded-xl font-semibold flex items-center justify-center gap-1.5 cursor-pointer text-center">
                                            <input 
                                                type="file" 
                                                accept=".json"
                                                onChange={(e) => {
                                                    const file = e.target.files[0];
                                                    if (file) {
                                                        const reader = new FileReader();
                                                        reader.onload = (event) => {
                                                            try {
                                                                const parsed = JSON.parse(event.target.result);
                                                                if (Array.isArray(parsed)) {
                                                                    setItems(parsed);
                                                                    triggerToast("导入成功");
                                                                    setActiveTab("gallery");
                                                                }
                                                            } catch (err) {
                                                                triggerToast("导入解析错误", "error");
                                                            }
                                                        };
                                                        reader.readAsText(file);
                                                    }
                                                }}
                                                className="hidden"
                                            />
                                            <Icon name="plus" className="w-4 h-4" />
                                            <span>导入恢复</span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    )}

                    {/* FIXED BOTTOM NAV BAR */}
                    <nav className="fixed bottom-0 left-0 right-0 max-w-md mx-auto bg-white/80 backdrop-blur-md border-t border-neutral-200/50 flex justify-around items-center py-2.5 px-6 z-40 shadow-lg">
                        <button 
                            onClick={() => { setActiveTab("gallery"); setSelectedItemId(null); }}
                            className={`flex flex-col items-center gap-1 py-1 px-3 rounded-xl transition ${activeTab === "gallery" || activeTab === "detail" ? "text-[#20252c]" : "text-neutral-400"}`}
                        >
                            <Icon name="search" className="w-5 h-5" />
                            <span className="text-[9px] font-semibold tracking-wider">我的馆藏</span>
                        </button>
                        
                        <button 
                            onClick={() => { setEditingItem(null); setActiveTab("add"); }}
                            className={`flex flex-col items-center gap-1 py-2 px-4 rounded-full transition-all duration-300 ${activeTab === "add" ? "bg-[#20252c] text-white scale-105" : "bg-neutral-100 text-neutral-600 hover:bg-neutral-200"}`}
                        >
                            <Icon name="plus" className="w-5 h-5" />
                        </button>

                        <button 
                            onClick={() => setActiveTab("settings")}
                            className={`flex flex-col items-center gap-1 py-1 px-3 rounded-xl transition ${activeTab === "settings" ? "text-[#20252c]" : "text-neutral-400"}`}
                        >
                            <Icon name="settings" className="w-5 h-5" />
                            <span className="text-[9px] font-semibold tracking-wider">系统配置</span>
                        </button>
                    </nav>

                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById("app"));
        root.render(<App />);
    </script>
</body>
</html>
